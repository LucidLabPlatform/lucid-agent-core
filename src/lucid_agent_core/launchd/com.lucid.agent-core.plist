<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lucid.agent-core</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/lucid/lucid-agent-core/venv/bin/lucid-agent-core</string>
        <string>run</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/lucid/lucid-agent-core</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <key>LUCID_MANAGED</key>
        <string>1</string>
        <key>LUCID_AGENT_BASE_DIR</key>
        <string>/Users/lucid/lucid-agent-core</string>
    </dict>
    <key>KeepAlive</key>
    <true/>
