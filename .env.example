# LUCID Agent Core configuration for systemd
# Copy this file to .env and fill in real values.
# Location on device: /etc/lucid/agent-core.env
#
# .env is gitignored — never commit real credentials.

# Required (service will fail to start if missing)
MQTT_HOST=<broker-ip>
MQTT_PORT=1883
AGENT_USERNAME=<agent-id>
AGENT_PASSWORD=<change-me>

# Optional
# AGENT_HEARTBEAT: seconds between retained "online" status updates (default: 30)
# AGENT_HEARTBEAT=30
